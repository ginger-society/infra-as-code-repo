{ 
  "HOSTING_FQDN": "shell(echo $HOSTING_FQDN)",
  "IAM_ADMIN": {
   "DB_URL": "shell(set -e; PW=$(kubectl get secret iam-postgresql -o jsonpath='{.data.postgres-password}' | base64 -d); echo postgresql://postgres:${PW}@iam-postgresql:5432/iam-db)",
    "ISC_SECRET": "verysecure"
  },
  "IAM": {
    "DB_URL": "shell(set -e; PW=$(kubectl get secret iam-postgresql -o jsonpath='{.data.postgres-password}' | base64 -d); echo postgresql://postgres:${PW}@iam-postgresql:5432/iam-db)",
    "ISC_SECRET": "verysecure"
  },
  "METADATA": {
    "DB_URL": "shell(set -e; PW=$(kubectl get secret metadata-postgresql -o jsonpath='{.data.postgres-password}' | base64 -d); echo postgresql://postgres:${PW}@metadata-postgresql:5432/metadata-db)",
    "ISC_SECRET": "verysecure"
  },
  "BUCKET": {
    "RESTIC_PASSWORD": "vault(BUCKET_RESTIC_PASSWORD)"
  },
   "PRESENCE": {
    "ISC_SECRET": "vault(PRESENCE_ISC_TOKEN)"
  },
  "TEKTON_SIDEKICK" : {
    "ISC_SECRET": "verysecure"
  },
   "EXECUTOR": {
    "ISC_SECRET": "vault(EXECUTOR_ISC_TOKEN)"
  },
  "GH_MIRROR": {
    "PAT": "file(./platform/artifactory/gitter/backup_account_pat) ",
    "SSH_PREFIX": "vault(GH_MIRROR_SSH_PREFIX)",
    "SSH_KEY": "file(./platform/artifactory/gitter/backup_account_ssh_key)",
    "USERNAME": "vault(GH_MIRROR_USERNAME)"
  },
  "GITOLITE": {
    "ADMIN_KEY_PUB": "file(./platform/artifactory/gitter/admin_key.pub)",
    "ADMIN_KEY": "file(./platform/artifactory/gitter/admin_key)",
    "CA_KEY": "file(./platform/mcs/iam-backend/ca_key)"
  },
  "DOCKER": {
    "REGISTRY_AUTH_CERT": "file(./platform/artifactory/docker-registry/auth.cert)",
    "REGISTRY_AUTH_PRIVATE_KEY": "file(./platform/mcs/iam-backend/auth.key)",
    "TOKEN_ISSUER": "my-auth-server",
    "MIRROR_SRC_USERNAME": "__token__",
    "MIRROR_SRC_PASSWORD": "vault(GINGER_DOCKER_REGISTRY_TOKEN)",
    "MIRROR_DEST_USERNAME": "vault(MIRROR_DEST_USERNAME)",
    "MIRROR_DEST_PASSWORD": "vault(MIRROR_DOCKER_REGISTRY_PAT)",
    "MIRROR_REPOS": "vault(MIRROR_REPOS)"
  },
  
  "NOTIFICATION": {
    "AWS_ACCESS_KEY_ID": "vault(AWS_ACCESS_KEY_ID)",
    "AWS_SECRET_ACCESS_KEY": "vault(AWS_SECRET_ACCESS_KEY)"
  },
  "shared": {
    "DATABASE_PASSWORD": "shell(kubectl get secret pg-postgresql -o jsonpath='{.data.postgres-password}' | base64 -d)",
    "JWT_SECRET_KEY": "vault(JWT_SECRET_KEY)",
    "ROCKET_SECRET_KEY": "onceshell(openssl rand -base64 64 | tr -d '\\n')",
    "RABBITMQ_DEFAULT_USER": "rabbiter",
    "RABBITMQ_DEFAULT_PASS": "vault(RABBITMQ_DEFAULT_PASS)"
  },
  "PIP": {
    "TOKEN": "vault(PYPI_SYNC_TOKEN)" 
  },
  "NPM": {
    "SYNC_TOKEN": "vault(NPM_SYNC_TOKEN)"
  }
}